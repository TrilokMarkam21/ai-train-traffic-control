# ============================================================
# AI Train Traffic Control — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB — REQUIRED
MONGO_URI=mongodb://localhost:27017/ai_train_traffic

# JWT — REQUIRED (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production
JWT_EXPIRES_IN=8h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# AI Microservice
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=5000

# Simulation speed (milliseconds between updates)
SIMULATION_INTERVAL_MS=3000

# Logging
LOG_LEVEL=info
